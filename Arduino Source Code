#include <Wire.h>                  // Library for I2C communication
#include <Adafruit_GFX.h>         // Graphics library for OLED display
#include <Adafruit_SSD1306.h>     // OLED display driver library

// OLED display dimensions
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64


Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// Pin definitions and variables
int soundPin = A0;        
int greenLED = 8;         
int redLED = 9;           

int threshold = 80;       // Noise threshold value
int violations = 0;       // Counts how many times noise exceeded threshold

void setup() {

  // Set LED pins as outputs
  pinMode(greenLED, OUTPUT);
  pinMode(redLED, OUTPUT);

  // Start serial monitor for debugging
  Serial.begin(9600);

  // Initialize OLED display
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);

  // Clear previous display data
  display.clearDisplay();

  // Text propetries 
  display.setTextSize(2);
  display.setTextColor(WHITE);

  // Display startup screen
  display.setCursor(0, 0);
  display.println("Noise");
  display.println("Monitor");
  display.display();

  // Keep startup screen visible for 2 seconds
  delay(2000);
}

void loop() {

  // Read analog value from sound sensor
  int soundValue = analogRead(soundPin);

  // Clear display before updating
  display.clearDisplay();

  // Display current sound value
  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("Noise: ");
  display.println(soundValue);

  // Display total alert count
  display.print("Alerts: ");
  display.println(violations);

  // Check if noise exceeds threshold
  if (soundValue > threshold) {

    // Increase violation count
    violations++;

    // Turn ON red LED and OFF green LED
    digitalWrite(redLED, HIGH);
    digitalWrite(greenLED, LOW);

    // Display warning message
    display.setTextSize(2);
    display.setCursor(0, 40);
    display.println("NOISY!");

    // Update OLED display
    display.display();

    // dekay of 2 seconds
    delay(2000);

    } 

    else {

    // Turn ON green LED and OFF red LED
    digitalWrite(greenLED, HIGH);
    digitalWrite(redLED, LOW);

    // Display of safe status
    display.setTextSize(2);
    display.setCursor(0, 40);
    display.println("QUIET ");

    // Updating the oled display
    display.display();
    }

  // Small delay
  delay(100);
}
